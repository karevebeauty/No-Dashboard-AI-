# Environment
NODE_ENV=development

# Server
PORT=3000
HOST=0.0.0.0

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WEBHOOK_URL=https://your-domain.com/sms/webhook

# Authorized Phone Numbers (comma-separated)
AUTHORIZED_PHONE_NUMBERS=+1234567890,+1987654321

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# PostgreSQL Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/sms_agent
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Session Configuration
SESSION_TTL=3600
SESSION_SECRET=your_random_session_secret_here

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100
RATE_LIMIT_PER_DAY=500
CONCURRENT_REQUESTS_LIMIT=3

# MCP Server Configuration
MCP_SERVER_PORT=3001
MCP_ENABLE_LOGGING=true

# Google Workspace (for MCP)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Notion Integration
NOTION_API_KEY=your_notion_integration_token

# Slack Integration
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Bridge Systems ERP API
ERP_API_URL=https://erp.bridgesystems.com/api
ERP_API_KEY=your_erp_api_key

# Warehouse Management API
WAREHOUSE_API_URL=https://warehouse.bridgesystems.com/api
WAREHOUSE_API_KEY=your_warehouse_api_key

# CareFlow Customer Support
CAREFLOW_API_URL=https://careflow.biz/api
CAREFLOW_API_KEY=your_careflow_api_key

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/sms-agent.log

# Cost Tracking
ENABLE_COST_TRACKING=true
COST_ALERT_THRESHOLD=100.00

# Security
ENCRYPTION_KEY=your_32_character_encryption_key_here
PIN_PROTECTION_ENABLED=false
PIN_CODE=1234

# Notification Service
ENABLE_NOTIFICATIONS=true
NOTIFICATION_QUIET_HOURS_START=22:00
NOTIFICATION_QUIET_HOURS_END=08:00

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=60000

# AWS Configuration (for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SECRETS_MANAGER_ENABLED=false

# Error Handling
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000
EXPONENTIAL_BACKOFF=true
